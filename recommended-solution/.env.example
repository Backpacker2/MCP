# Claude Credits Monitor - Configuratie
# Kopieer dit bestand naar .env en vul je gegevens in

# ──────────────────────────────────────────────────
# VERPLICHT: kies je notificatieprovider
# Opties: pushover | telegram | textbee | twilio
# ──────────────────────────────────────────────────
NOTIFICATION_PROVIDER=pushover

# ──────────────────────────────────────────────────
# PUSHOVER (aanbevolen)
# Setup: https://pushover.net/
# Kosten: €4.99 eenmalig voor de app
# Gratis: 10.000 notificaties per maand
# ──────────────────────────────────────────────────
PUSHOVER_TOKEN=your_application_token_here
PUSHOVER_USER=your_user_key_here

# ──────────────────────────────────────────────────
# TELEGRAM (gratis alternatief)
# Setup:
#   1. Zoek @BotFather op Telegram
#   2. Maak een nieuwe bot (/newbot)
#   3. Stuur een bericht naar je bot
#   4. Haal je chat_id op: python claude_monitor.py --telegram-id
# ──────────────────────────────────────────────────
# NOTIFICATION_PROVIDER=telegram
# TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOP
# TELEGRAM_CHAT_ID=123456789

# ──────────────────────────────────────────────────
# TEXTBEE (echte SMS, gratis 300/mnd)
# Setup: https://textbee.dev/
#   1. Download app op Android
#   2. Registreer op textbee.dev
#   3. Koppel je telefoon via QR code
# ──────────────────────────────────────────────────
# NOTIFICATION_PROVIDER=textbee
# TEXTBEE_API_KEY=your_api_key_here
# TEXTBEE_DEVICE_ID=your_device_id_here
# TEXTBEE_RECIPIENT=+31612345678

# ──────────────────────────────────────────────────
# TWILIO (meest betrouwbaar, kleine kosten)
# Setup: https://twilio.com/
# Kosten: ~€0.008 per SMS, $15 trial credit
# ──────────────────────────────────────────────────
# NOTIFICATION_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_FROM=+1xxxxxxxxxx
# TWILIO_TO=+31612345678

# ──────────────────────────────────────────────────
# Monitor instellingen
# ──────────────────────────────────────────────────

# Interval tussen checks in seconden (standaard: 600 = 10 minuten)
CHECK_INTERVAL=600

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
